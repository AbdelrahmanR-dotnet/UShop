@model Customer

@{
    ViewData["Title"] = "My Profile";
}

<div class="container mt-5">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="fw-bold"><i class="fa-solid fa-user-circle text-primary me-2"></i>My Dashboard</h2>
        <form asp-controller="Account" asp-action="Logout" method="post">
            <button type="submit" class="btn btn-outline-danger rounded-pill px-4">
                <i class="fa-solid fa-right-from-bracket me-1"></i> Sign Out
            </button>
        </form>
    </div>

    <div class="row g-4">
        <div class="col-lg-4">
            <div class="card border-0 shadow-sm rounded-4 mb-4 text-center overflow-hidden">
                <div class="bg-primary" style="height: 100px;"></div>
                <div class="card-body px-4 pb-4" style="margin-top: -50px;">
                    <div class="bg-white rounded-circle d-inline-flex p-2 shadow-sm mb-3">
                        <div class="bg-light rounded-circle d-flex align-items-center justify-content-center"
                             style="width: 80px; height: 80px;">
                            <span
                                class="fs-1 fw-bold text-primary">@(Model.FullName?.Substring(0, 1).ToUpper() ?? "U")</span>
                        </div>
                    </div>
                    <h4 class="fw-bold mb-1">@Model.FullName</h4>
                    <p class="text-muted mb-3">@Model.Email</p>

                    <a asp-controller="Customer" asp-action="Edit" asp-route-id="@Model.Id"
                       class="btn btn-primary rounded-pill w-100 fw-semibold mb-2">
                        <i class="fa-solid fa-pen-to-square me-1"></i> Edit Profile
                    </a>
                </div>
            </div>

            <div class="card border-0 shadow-sm rounded-4">
                <div
                    class="card-header bg-white border-bottom-0 pt-4 pb-0 px-4 d-flex justify-content-between align-items-center">
                    <h6 class="fw-bold mb-0"><i class="fa-solid fa-location-dot me-2 text-danger"></i>Shipping Address
                    </h6>
                </div>
                <div class="card-body p-4">
                    @if (Model.Address != null && !string.IsNullOrEmpty(Model.Address.Street))
                    {
                        <p class="mb-1">@Model.Address.Street</p>
                        <p class="mb-1">@Model.Address.City</p>
                        <p class="mb-0">@Model.Address.Country</p>
                    }
                    else
                    {
                        <div class="alert alert-warning py-2 mb-0 small">
                            <i class="fa-solid fa-triangle-exclamation me-1"></i> Address not set.
                        </div>
                    }
                </div>
            </div>
        </div>

        <div class="col-lg-8">
            <div class="card border-0 shadow-sm rounded-4 h-100">
                <div
                    class="card-header bg-white border-bottom-0 pt-4 pb-3 px-4 d-flex justify-content-between align-items-center">
                    <h5 class="fw-bold mb-0"><i class="fa-solid fa-box-open me-2 text-success"></i>Recent Orders</h5>
                    <a asp-controller="Orders" asp-action="Index"
                       class="text-decoration-none text-primary small fw-semibold">View All</a>
                </div>
                <div class="card-body p-0">
                    @if (Model.Orders != null && Model.Orders.Any())
                    {
                        <div class="table-responsive">
                            <table class="table table-hover align-middle mb-0">
                                <thead class="table-light">
                                <tr>
                                    <th class="ps-4">Order ID</th>
                                    <th>Date</th>
                                    <th>Status</th>
                                    <th class="text-end pe-4">Action</th>
                                </tr>
                                </thead>
                                <tbody>
                                @foreach (var order in Model.Orders.OrderByDescending(o => o.OrderDate).Take(5))
                                {
                                    <tr>
                                        <td class="ps-4 fw-semibold text-muted">#@order.Id</td>
                                        <td>@order.OrderDate.ToString("MMM dd, yyyy")</td>
                                        <td>
                                            @{
                                                var badgeClass = order.Status switch
                                                {
                                                    OrderStatus.Pending => "bg-warning text-dark",
                                                    OrderStatus.Processing => "bg-info text-dark",
                                                    OrderStatus.Shipped => "bg-primary",
                                                    OrderStatus.Delivered => "bg-success",
                                                    OrderStatus.Cancelled => "bg-danger",
                                                    _ => "bg-secondary"
                                                };
                                            }
                                            <span class="badge @badgeClass">@order.Status</span>
                                        </td>
                                        <td class="text-end pe-4">
                                            <a asp-controller="Orders" asp-action="Details" asp-route-id="@order.Id"
                                               class="btn btn-sm btn-outline-secondary rounded-pill px-3">
                                                Details
                                            </a>
                                        </td>
                                    </tr>
                                }
                                </tbody>
                            </table>
                        </div>
                    }
                    else
                    {
                        <div class="text-center py-5">
                            <i class="fa-solid fa-receipt fs-1 text-muted mb-3 opacity-50"></i>
                            <p class="text-muted">You haven't placed any orders yet.</p>
                            <a asp-controller="Products" asp-action="Shopping"
                               class="btn btn-outline-primary rounded-pill">Start Shopping</a>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</div>