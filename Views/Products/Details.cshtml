@model UShop.Models.Product

@{
    ViewData["Title"] = Model.Name;
}

<div class="container mt-5">
    <nav aria-label="breadcrumb" class="mb-4">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a asp-action="Shopping" class="text-decoration-none">Shop</a></li>
            <li class="breadcrumb-item"><a asp-action="Shopping" asp-route-categoryId="@Model.CategoryId" class="text-decoration-none">@(Model.Category?.Name ?? "Category")</a></li>
            <li class="breadcrumb-item active" aria-current="page">@Model.Name</li>
        </ol>
    </nav>

    <div class="row bg-white p-4 rounded-3 shadow-sm border">
        <div class="col-md-6 mb-4 mb-md-0">
            <div class="rounded overflow-hidden bg-light d-flex align-items-center justify-content-center shadow-sm" style="min-height: 400px;">
                @if (!string.IsNullOrEmpty(Model.ImageUrl))
                {
                    <img src="@Model.ImageUrl" class="img-fluid" alt="@Model.Name" />
                }
                else
                {
                    <i class="fa-solid fa-box fs-1 text-muted"></i>
                }
            </div>
        </div>

        <div class="col-md-6 d-flex flex-column justify-content-center px-md-5">
            <h1 class="fw-bold mb-2">@Model.Name</h1>
            <div class="d-flex align-items-center mb-3">
                <span class="badge bg-primary me-2 fs-6">@Model.Category?.Name</span>
                <span class="text-muted"><i class="fa-solid fa-store me-1"></i> Sold by: <span class="fw-semibold text-dark">@Model.Seller?.FullName</span></span>
            </div>

            <h2 class="text-success fw-bold mb-4">$@Model.Price.ToString("0.00")</h2>

            <p class="text-muted lh-lg mb-4">
                @(string.IsNullOrWhiteSpace(Model.Description) ? "No description available for this product." : Model.Description)
            </p>

            <div class="mb-4">
                @if (Model.StockQuantity > 0)
                {
                    <span class="text-success fw-bold"><i class="fa-solid fa-check-circle me-1"></i> In Stock (@Model.StockQuantity available)</span>
                }
                else
                {
                    <span class="text-danger fw-bold"><i class="fa-solid fa-xmark-circle me-1"></i> Out of Stock</span>
                }
            </div>

            @if (Model.StockQuantity > 0)
            {
                <div class="d-flex gap-3 mt-auto">
                    <form asp-controller="Cart" asp-action="AddToCart" method="post" class="flex-grow-1">
                        <input type="hidden" name="productId" value="@Model.Id" />
                        <div class="input-group mb-3">
                            <span class="input-group-text bg-light">Qty</span>
                            <input type="number" name="quantity" value="1" min="1" max="@Model.StockQuantity" class="form-control" />
                        </div>
                        <button type="submit" class="btn btn-outline-primary btn-lg w-100 fw-bold">
                            <i class="fa-solid fa-cart-plus me-2"></i>Add to Cart
                        </button>
                    </form>

                    <form asp-controller="Cart" asp-action="BuyNow" method="get" class="flex-grow-1">
                        <input type="hidden" name="productId" value="@Model.Id" />
                        <input type="hidden" name="quantity" value="1" id="buyNowQty" />
                        <div class="mb-3" style="height: 38px;"></div> <button type="submit" class="btn btn-primary btn-lg w-100 fw-bold shadow-sm" onclick="document.getElementById('buyNowQty').value = this.form.previousElementSibling.querySelector('input[name=quantity]').value">
                            <i class="fa-solid fa-bolt me-2"></i>Buy Now
                        </button>
                    </form>
                </div>
            }
            else
            {
                <button class="btn btn-secondary btn-lg w-100 disabled" mt-auto>Currently Unavailable</button>
            }
        </div>
    </div>
</div>