@model Customer

@{
    ViewData["Title"] = "Complete Your Profile";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="card shadow-sm border-0 rounded-3">
                <div class="card-header bg-white border-bottom-0 pt-4 pb-0 px-4">
                    <h4 class="fw-bold"><i class="fa-solid fa-address-card text-primary me-2"></i>Update Profile &
                        Address</h4>
                    <p class="text-muted small">We need your shipping details to complete your order.</p>
                </div>
                <div class="card-body p-4">
                    <form asp-action="Edit" method="post">
                        <input type="hidden" asp-for="Id"/>
                        <input type="hidden" asp-for="Email"/> <h6 class="fw-bold mb-3 text-muted border-bottom pb-2">
                            Personal Information</h6>
                        <div class="row g-3 mb-4">
                            <div class="col-md-6">
                                <label asp-for="FullName" class="form-label fw-semibold">Full Name</label>
                                <input asp-for="FullName" class="form-control bg-light"/>
                                <span asp-validation-for="FullName" class="text-danger small"></span>
                            </div>
                            <div class="col-md-6">
                                <label asp-for="PhoneNumber" class="form-label fw-semibold">Phone Number</label>
                                <input asp-for="PhoneNumber" class="form-control bg-light"
                                       placeholder="+1 (555) 000-0000"/>
                            </div>
                        </div>

                        <h6 class="fw-bold mb-3 text-muted border-bottom pb-2">Shipping Address</h6>
                        <div class="row g-3 mb-4">
                            <div class="col-12">
                                <label asp-for="Address.Street" class="form-label fw-semibold">Street Address</label>
                                <input asp-for="Address.Street" class="form-control bg-light"
                                       placeholder="123 Main St, Apt 4B" required/>
                            </div>
                            <div class="col-md-6">
                                <label asp-for="Address.City" class="form-label fw-semibold">City</label>
                                <input asp-for="Address.City" class="form-control bg-light" placeholder="New York"
                                       required/>
                            </div>
                            <div class="col-md-6">
                                <label asp-for="Address.Country" class="form-label fw-semibold">Country</label>
                                <input asp-for="Address.Country" class="form-control bg-light"
                                       placeholder="United States" required/>
                            </div>
                        </div>

                        <div class="d-flex justify-content-between mt-4">
                            <a asp-controller="Checkout" asp-action="Index"
                               class="btn btn-outline-secondary rounded-pill px-4">Cancel</a>
                            <button type="submit" class="btn btn-primary px-5 fw-bold rounded-pill shadow-sm">
                                Save & Continue <i class="fa-solid fa-arrow-right ms-2"></i>
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{ await Html.RenderPartialAsync("_ValidationScriptsPartial"); }
}